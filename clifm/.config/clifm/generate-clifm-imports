#!/usr/bin/env bash
# generate-clifm-imports: Extract aliases and portable functions from user-modules
# and generate clifmrc entries + shell scripts for clifm

CLIFM_CONFIG="${HOME}/.config/clifm"
CLIFM_SCRIPTS="${CLIFM_CONFIG}/scripts"
USER_MODULES="${HOME}/.config/zsh/user-modules"

# Functions that cannot work as scripts
# Note: Any function starting with _ or _z is treated as internal/non-portable
NON_PORTABLE="cdl yazi-cwd pick update_pane_title _zellij_download_plugin _zellij_process_plugins"
CLIFM_INTERNAL="quit exit cd ls select history parent bookmarks search sort filter show hide mkdir edit"

# Colors
BLUE='\033[34m'
YELLOW='\033[33m'
GREEN='\033[32m'
NC='\033[0m'

mkdir -p "$CLIFM_SCRIPTS"

echo -e "${BLUE}=== Generating clifm Imports ===${NC}\n"

# ═══════════════════════════════════════════════════
# Extract aliases
# ═══════════════════════════════════════════════════

echo -e "${BLUE}Extracting aliases...${NC}"

ALIASES_COUNT=0
CONFLICTS_COUNT=0
CLIFMRC_ALIASES=$(mktemp)

# Get all aliases, remove file path prefix, check for conflicts
grep "^alias " "$USER_MODULES"/*.zsh 2>/dev/null | cut -d: -f2- | sort -u | while read -r alias_line; do
  name=$(echo "$alias_line" | sed -E 's/^alias ([^=]+)=.*/\1/')
  command_part=$(echo "$alias_line" | sed -E "s/^alias [^=]*='?//" | sed "s/'$//")

  if echo "$CLIFM_INTERNAL" | grep -qw "$name"; then
    echo -e "${YELLOW}⚠ CONFLICT${NC}: '$name' is a clifm command (skipped)"
  elif echo "$NON_PORTABLE" | grep -qwE "$(echo $command_part | cut -d' ' -f1)"; then
    echo -e "${YELLOW}⊘ SKIPPED${NC}: '$name' depends on non-portable function"
  else
    echo "$alias_line" >> "$CLIFMRC_ALIASES"
  fi
done

ALIASES_COUNT=$(wc -l < "$CLIFMRC_ALIASES" || echo 0)

# ═══════════════════════════════════════════════════
# Extract functions and generate scripts
# ═══════════════════════════════════════════════════

echo -e "\n${BLUE}Processing functions...${NC}"

FUNCTIONS_COUNT=0
SKIPPED_COUNT=0
CLIFMRC_FUNCTIONS=$(mktemp)

# Get all unique function names
grep -h "^[a-zA-Z_][a-zA-Z0-9_-]*() {" "$USER_MODULES"/*.zsh 2>/dev/null | \
  sed 's/() {//' | sort -u | while read -r func_name; do

  # Skip if in NON_PORTABLE list OR starts with _z
  if echo "$NON_PORTABLE" | grep -qw "$func_name" || [[ "$func_name" =~ ^_z ]]; then
    echo -e "${YELLOW}⊘ SKIPPED${NC}: $func_name (not portable)"
  elif echo "$CLIFM_INTERNAL" | grep -qw "$func_name"; then
    echo -e "${YELLOW}⚠ CONFLICT${NC}: '$func_name' is a clifm command (skipped)"
  else
    # Find the file with this function
    for f in "$USER_MODULES"/*.zsh; do
      if grep -q "^$func_name() {" "$f" 2>/dev/null; then
        script_file="$CLIFM_SCRIPTS/$func_name"

        # Extract and write function script
        {
          echo "#!/usr/bin/env zsh"
          echo "# Generated function script: $func_name"
          echo "# Source: ~/.config/zsh/user-modules/"
          echo ""
          echo "# Source helper functions and utilities"
          echo "source $USER_MODULES/zsh.zsh 2>/dev/null || true"
          echo ""
          awk "/^$func_name\(\) \{/,/^}/" "$f"
          echo ""
          echo "$func_name \"\$@\""
        } > "$script_file"

        chmod +x "$script_file"
        echo -e "${GREEN}✓ GENERATED${NC}: $func_name"
        echo "alias $func_name='$script_file'" >> "$CLIFMRC_FUNCTIONS"
        break
      fi
    done
  fi
done

FUNCTIONS_COUNT=$(wc -l < "$CLIFMRC_FUNCTIONS" || echo 0)
SKIPPED_COUNT=$(grep "SKIPPED" 2>/dev/null | wc -l || echo 0)

# ═══════════════════════════════════════════════════
# Output clifmrc entries
# ═══════════════════════════════════════════════════

echo -e "\n${BLUE}Generated clifmrc entries:${NC}\n"

# Aliases
if [[ -s "$CLIFMRC_ALIASES" ]]; then
  echo "# ═══════════════════════════════════════════════════"
  echo "# Aliases (generated by generate-clifm-imports)"
  echo "# Generated: $(date)"
  echo "# ═══════════════════════════════════════════════════"
  cat "$CLIFMRC_ALIASES"
fi

# Functions
if [[ -s "$CLIFMRC_FUNCTIONS" ]]; then
  echo ""
  echo "# ═══════════════════════════════════════════════════"
  echo "# Function scripts (as aliases)"
  echo "# ═══════════════════════════════════════════════════"
  cat "$CLIFMRC_FUNCTIONS"
fi

# ═══════════════════════════════════════════════════
# Summary
# ═══════════════════════════════════════════════════

echo ""
echo -e "${BLUE}=== Summary ===${NC}"
echo "Aliases generated:        $(cat $CLIFMRC_ALIASES | wc -l)"
echo "Function scripts created: $(cat $CLIFMRC_FUNCTIONS | wc -l)"
echo "Functions skipped:        $SKIPPED_COUNT (not portable)"

echo -e "\n${BLUE}Next steps:${NC}"
echo "1. Review the generated entries above"
echo "2. Append to clifmrc:"
echo "   $0 >> ~/.config/clifm/profiles/default/clifmrc"

echo -e "\n${YELLOW}Functions that remain zsh-only (parent shell state):${NC}"
for func in $NON_PORTABLE; do
  echo "  • $func"
done

echo -e "\n${BLUE}Generated scripts location:${NC} $CLIFM_SCRIPTS"
if [[ -d "$CLIFM_SCRIPTS" && -n "$(ls -1 "$CLIFM_SCRIPTS" 2>/dev/null | grep -v '^\.')" ]]; then
  ls -1 "$CLIFM_SCRIPTS" | grep -v '^\.'
fi

# Cleanup
rm -f "$CLIFMRC_ALIASES" "$CLIFMRC_FUNCTIONS"

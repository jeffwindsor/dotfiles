#!/usr/bin/env zsh
# Generated function script: mise-sync
# Source: ~/.config/zsh/user-modules/

# Source helper functions and utilities
source /Users/jefwinds/.config/zsh/user-modules/zsh.zsh 2>/dev/null || true

mise-sync() {
  print_section "Mise: Syncing Global"
  cd "$HOME"
  mise trust
  mise install
  cd - > /dev/null
}

mise-sync "$@"

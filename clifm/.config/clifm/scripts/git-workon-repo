#!/usr/bin/env zsh
# Generated function script: git-workon-repo
# Source: ~/.config/zsh/user-modules/

# Source helper functions and utilities
source /Users/jefwinds/.config/zsh/user-modules/zsh.zsh 2>/dev/null || true

git-workon-repo() {
  local repo=$(tv my-git-repos)
  if [[ -n "$repo" ]]; then 
    cd "$repo"
    zellij --layout claude
  fi
}

git-workon-repo "$@"

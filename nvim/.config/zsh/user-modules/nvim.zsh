#!/usr/bin/env zsh
alias v='NVIM_APPNAME=nvim-lazyvim nvim'
alias v.='NVIM_APPNAME=nvim-lazyvim nvim .'
alias vm='NVIM_APPNAME=nvim-minimax nvim'
alias vm.='NVIM_APPNAME=nvim-minimax nvim .'
alias vp='NVIM_APPNAME=nvim-personal nvim'
alias vp.='NVIM_APPNAME=nvim-personal nvim .'

alias md='cd ~/markdown/'
alias mde='cd ~/markdown/ && nvim'

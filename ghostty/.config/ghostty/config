#== Appearance ==
confirm-close-surface = false
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 16
quit-after-last-window-closed = true
theme = tinted-theming
macos-titlebar-style = hidden
window-padding-x = 4
window-padding-y = 4

#== Keybindings ==
# ghostty-specific
keybind = global:cmd+grave_accent=toggle_quick_terminal
keybind = shift+enter=text:\n
# tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+i=prompt_tab_title
keybind = cmd+bracket_left=previous_tab
keybind = cmd+bracket_right=next_tab
# panes
keybind = cmd+enter=new_split:right
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down
keybind = cmd+shift+f=toggle_split_zoom
